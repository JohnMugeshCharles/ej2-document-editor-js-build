{
    "name": "@syncfusion/ej2-documents-js-samples",
    "version": "1.0.0",
    "description": "Examples of JavaScript (ES5) UI Controls",
    "author": "Syncfusion Inc.",
    "license": "SEE LICENSE IN license",
    "dependencies": {
        "@syncfusion/ej2": "*",
        "crossroads": "0.12.2",
        "hasher": "1.2.0",
        "simple-git": "3.16.0",
        "fuse.js": "7.0.0",
        "tributejs": "5.1.3"
    },
    "devDependencies": {
        "@syncfusion/ej2-documents-sample-helper": "*",
        "gulp": "^4.0.2",
        "gulp-cli": "^2.3.0"
    },
    "scripts": {
        "doc-build": "gulp document-split && gulp document-build && gulp publish-build-documents-sample",
        "build": "gulp build-service-url && gulp document-sdk-es-build",
		"sb-build": "gulp document-es-build",
		"es-build": "gulp restore-service-url && gulp hide-license && gulp hide-license-sdk && gulp document-sdk-es-build",
        "test": "gulp webservice-url && gulp document-sdk-es-build && gulp pdfium-wasm && gulp styles-ship && gulp sitemap-generate",
        "ci-publish": "gulp commit-common && gulp publish-document-samples"
    },
    "config": {
        "ghooks": {
            "pre-commit": "npm run test",
            "commit-msg": "gulp commit-message"
        }
    }
}
